# Your domain (e.g. example.com)
DOMAIN=yourdomain.com

# Grafana admin password
GF_ADMIN_PASSWORD=change_me_strong_password

# Authentik OAuth application credentials
# Create an OAuth2 provider in Authentik and paste the client ID/secret here
GF_OAUTH_CLIENT_ID=your_authentik_client_id
GF_OAUTH_CLIENT_SECRET=your_authentik_client_secret
